{
  "manifest_version": 3,
  "name": "Cursive AI — Lead Enrichment",
  "version": "1.0.0",
  "description": "Real-time lead enrichment, email verification, and contact discovery powered by Cursive AI's 280M+ identity graph.",
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus"
  ],
  "host_permissions": [
    "https://leads.meetcursive.com/api/ext/*",
    "https://www.linkedin.com/*",
    "https://mail.google.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*", "https://www.linkedin.com/sales/*"],
      "js": ["content/linkedin.js"],
      "css": ["content/linkedin.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content/gmail.js"],
      "css": ["content/gmail.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.svg",
      "32": "icons/icon-32.svg",
      "48": "icons/icon-48.svg",
      "128": "icons/icon-128.svg"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon-16.svg",
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  }
}
