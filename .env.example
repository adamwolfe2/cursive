# ==============================================
# Cursive Platform - Environment Variables
# ==============================================
# Copy this file to .env.local and fill in your values

# ==============================================
# SUPABASE (Required)
# ==============================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ==============================================
# APPLICATION URLs (Required)
# ==============================================
# REQUIRED: Google OAuth callback URL is built from NEXT_PUBLIC_SITE_URL — OAuth fails without it
NEXT_PUBLIC_SITE_URL=https://leads.meetcursive.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PRODUCTION_URL=https://app.meetcursive.com

# ==============================================
# AI SERVICES
# ==============================================
# Anthropic Claude API (Required for AI features)
ANTHROPIC_API_KEY=your_anthropic_api_key

# ==============================================
# DATA ENRICHMENT PROVIDERS
# ==============================================

# Clay API (Contact enrichment)
CLAY_API_KEY=your_clay_api_key
CLAY_API_URL=https://api.clay.com/v1
CLAY_WEBHOOK_SECRET=your_clay_webhook_secret

# Audience Labs (SuperPixel + AudienceSync + Export imports)
# Webhook secret: validates inbound SuperPixel & AudienceSync webhooks
AUDIENCELAB_WEBHOOK_SECRET=your_audiencelab_webhook_secret
# Pixel ID: optional, can be derived from event payloads
AUDIENCELAB_PIXEL_ID=
# Account API key: for future REST API use (list audiences, get files)
AUDIENCELAB_ACCOUNT_API_KEY=

# Firecrawl (Website scraping)
FIRECRAWL_API_KEY=your_firecrawl_api_key
FIRECRAWL_API_URL=https://api.firecrawl.dev/v1

# Tavily (Company research fallback)
TAVILY_API_KEY=your_tavily_api_key

# ==============================================
# GEOCODING SERVICES
# ==============================================
# Google Maps API (Primary geocoding)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Mapbox (Geocoding fallback)
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# ==============================================
# CRM INTEGRATIONS
# ==============================================
# GoHighLevel OAuth (for customer workspace connections)
GHL_CLIENT_ID=your_ghl_client_id
GHL_CLIENT_SECRET=your_ghl_client_secret

# GoHighLevel Admin (Cursive's own GHL account - Private Integration Tokens)
GHL_CURSIVE_LOCATION_TOKEN=your_ghl_location_pit
GHL_CURSIVE_AGENCY_TOKEN=your_ghl_agency_pit
GHL_CURSIVE_LOCATION_ID=your_ghl_location_id
GHL_CURSIVE_COMPANY_ID=your_ghl_company_id

# ==============================================
# PAYMENT PROCESSING
# ==============================================
# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Stripe Product/Price IDs
STRIPE_FREE_PRODUCT_ID=your_stripe_free_product_id
STRIPE_PRO_PRODUCT_ID=your_stripe_pro_product_id
STRIPE_PRO_MONTHLY_PRICE_ID=your_stripe_pro_monthly_price_id
STRIPE_PRO_YEARLY_PRICE_ID=your_stripe_pro_yearly_price_id

# ==============================================
# EMAIL SERVICES
# ==============================================
# Resend (Transactional email - REQUIRED for email notifications)
RESEND_API_KEY=your_resend_api_key

# Email addresses
EMAIL_FROM=Cursive <notifications@meetcursive.com>
SUPPORT_EMAIL=support@meetcursive.com

# ==============================================
# EMAIL BISON (AI Email Agent Integration)
# ==============================================
# EmailBison is used for cold email campaigns and receiving replies
# Get your API key from EmailBison dashboard → Settings → Developer API
EMAILBISON_API_KEY=your_emailbison_api_key
EMAILBISON_API_URL=https://send.meetcursive.com
EMAILBISON_WEBHOOK_SECRET=your_emailbison_webhook_secret
# Default sender account ID (can be overridden per campaign)
EMAILBISON_DEFAULT_ACCOUNT_ID=your_default_account_id

# ==============================================
# AI EMAIL AGENT
# ==============================================
# Anthropic Claude API key (PRIMARY - recommended)
# Used for email generation, intent classification, and campaign building
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI API key (FALLBACK)
# Used if Anthropic key is not available
OPENAI_API_KEY=your_openai_api_key

# Fal.ai API key (REQUIRED for AI Studio image generation)
# Used for generating ad creatives with Flux models
# Get your key at: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_api_key

# ==============================================
# EMAIL VERIFICATION (Lead Marketplace)
# ==============================================
# MillionVerifier - used for email verification
MILLIONVERIFIER_API_KEY=your_millionverifier_api_key

# Kill switch - set to 'true' to disable email verification
EMAIL_VERIFICATION_KILL_SWITCH=false

# ==============================================
# BACKGROUND JOBS
# ==============================================
# Inngest
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key

# Cron security (REQUIRED - must also be set in Vercel project settings for cron to work)
CRON_SECRET=your-secret-here

# ==============================================
# SMS & VOICE (Optional)
# ==============================================
# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# ==============================================
# MONITORING & LOGGING (Optional)
# ==============================================
# Sentry (Error tracking and performance monitoring)
# Get your DSN from: https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_DEV_ENABLED=false # Set to true to send events from dev environment

# Slack Alerts (Webhook for critical alerts)
# Create webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/... # ops alerts
SLACK_SALES_WEBHOOK_URL=https://hooks.slack.com/services/... # REQUIRED: custom audience lead notifications

# =============================================
# INTELLIGENCE LAYER PROVIDERS
# =============================================
# Proxycurl — LinkedIn profile enrichment (~$0.03/profile)
# Sign up: https://nubela.co/proxycurl
PROXYCURL_API_KEY=

# FullContact — Social profile intelligence (~$0.02/lookup)
# Sign up: https://dashboard.fullcontact.com
FULLCONTACT_API_KEY=

# Serper — News mention search (~$0.001/query)
# Sign up: https://serper.dev
SERPER_API_KEY=

# Perplexity — Deep research AI (~$0.005-0.02/query)
# Sign up: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# BuiltWith — Tech stack detection (API plan required)
# Sign up: https://api.builtwith.com
BUILTWITH_API_KEY=

# EmailRep — Email quality scoring (free tier available)
# Sign up: https://emailrep.io
EMAILREP_API_KEY=

# Intelligence rate limits (requests per Inngest function invocation)
# Tune these to match your API plan limits and avoid overage charges
INTELLIGENCE_BUILTWITH_LIMIT=5
INTELLIGENCE_EMAILREP_LIMIT=20
INTELLIGENCE_PROXYCURL_LIMIT=10
INTELLIGENCE_FULLCONTACT_LIMIT=10
INTELLIGENCE_SERPER_LIMIT=20
INTELLIGENCE_PERPLEXITY_LIMIT=3
