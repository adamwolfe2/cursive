# ==============================================
# Cursive Platform - Environment Variables
# ==============================================
# Copy this file to .env.local and fill in your values

# ==============================================
# SUPABASE (Required)
# ==============================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ==============================================
# APPLICATION URLs (Required)
# ==============================================
NEXT_PUBLIC_SITE_URL=https://leads.meetcursive.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================================
# AI SERVICES
# ==============================================
# Anthropic Claude API (Required for AI features + Audience Copilot)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Admin Audience Copilot — daily USD spend kill-switch (default: 20)
COPILOT_DAILY_USD_CAP=20

# OpenAI API key (Fallback + segment embeddings)
OPENAI_API_KEY=your_openai_api_key

# Google Gemini (Optional)
GEMINI_API_KEY=your_gemini_api_key

# Fal.ai (Required for AI Studio image generation)
FAL_KEY=your_fal_api_key

# ==============================================
# DATA ENRICHMENT PROVIDERS
# ==============================================
# Clay API (Contact enrichment)
CLAY_API_KEY=your_clay_api_key

# Audience Labs (SuperPixel + AudienceSync)
AUDIENCELAB_WEBHOOK_SECRET=your_audiencelab_webhook_secret
AUDIENCELAB_PIXEL_ID=
AUDIENCELAB_ACCOUNT_API_KEY=

# Firecrawl (Website scraping)
FIRECRAWL_API_KEY=your_firecrawl_api_key

# Tavily (Company research)
TAVILY_API_KEY=your_tavily_api_key

# BuiltWith (Tech stack detection)
BUILTWITH_API_KEY=your_builtwith_api_key

# Autonoma (Data automation)
AUTONOMA_CLIENT_ID=your_autonoma_client_id
AUTONOMA_SECRET_ID=your_autonoma_secret_id

# ==============================================
# CRM INTEGRATIONS
# ==============================================
# GoHighLevel — OAuth (customer-facing CRM connection)
# Create a Marketplace app at https://marketplace.gohighlevel.com → developer account
# Scopes (must match what's enabled on the app):
#   contacts.readonly contacts.write opportunities.readonly opportunities.write
#   locations.readonly workflows.readonly conversations.readonly conversations.write
#   conversations/message.readonly conversations/message.write calendars/events.readonly
GHL_CLIENT_ID=your_ghl_marketplace_app_client_id
GHL_CLIENT_SECRET=your_ghl_marketplace_app_client_secret
# GHL Marketplace RSA public key — OPTIONAL override.
# The well-known key is hard-coded in /api/webhooks/leadconnector/route.ts.
# Only set this if GHL rotates their key and you need to override before redeploying.
# Source: https://marketplace.gohighlevel.com/docs/webhook/WebhookIntegrationGuide
# GHL_MARKETPLACE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
#
# GHL Marketplace Ed25519 public key — OPTIONAL, enables faster verification.
# GHL sends BOTH x-ghl-signature (Ed25519) and x-wh-signature (RSA) on every
# webhook. Set this to prefer Ed25519 with RSA as fallback.
# Value: base64-encoded raw 32-byte Ed25519 key from the same docs page
# (→ "Ed25519 Signature Verification" section).
# GHL_MARKETPLACE_ED25519_KEY=base64_encoded_32_byte_ed25519_key

# GoHighLevel — Admin (Cursive's own agency/location for DFY sub-account provisioning)
GHL_CURSIVE_LOCATION_TOKEN=your_ghl_location_pit
GHL_CURSIVE_AGENCY_TOKEN=your_ghl_agency_pit
GHL_CURSIVE_LOCATION_ID=your_ghl_location_id
GHL_CLIENT_SNAPSHOT_ID=your_ghl_snapshot_id
GHL_SNAPSHOT_ID=your_ghl_snapshot_id

# Shopify — OAuth + webhook verification (Shopify Partner app)
# Create at https://partners.shopify.com → Apps → your app
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_customers,read_orders,read_products,write_customers
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_signing_secret
SHOPIFY_APP_URL=https://leads.meetcursive.com

# ==============================================
# PAYMENT PROCESSING
# ==============================================
# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Stripe Price IDs
STRIPE_PRO_MONTHLY_PRICE_ID=your_stripe_pro_monthly_price_id
STRIPE_LEAD_PRICE_ID=your_stripe_lead_price_id

# ==============================================
# EMAIL SERVICES
# ==============================================
# Resend (Transactional email)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=Cursive <notifications@meetcursive.com>

# EmailBison (Cold email campaigns)
EMAILBISON_API_KEY=your_emailbison_api_key
EMAILBISON_API_URL=https://send.meetcursive.com

# ==============================================
# BACKGROUND JOBS
# ==============================================
# Inngest
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key

# Cron security
CRON_SECRET=your-secret-here

# ==============================================
# MONITORING & OBSERVABILITY
# ==============================================
# Sentry
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org

# PostHog (Analytics)
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Slack Alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_SALES_WEBHOOK_URL=https://hooks.slack.com/services/...

# OpenTelemetry / Dash0 (Optional)
OTEL_EXPORTER_OTLP_ENDPOINT=your_otel_endpoint
OTEL_EXPORTER_OTLP_HEADERS=your_otel_headers
OTEL_EXPORTER_OTLP_COMPRESSION=gzip
DASH0_AUTH_TOKEN=your_dash0_auth_token
DASH0_DATASET=your_dash0_dataset

# ==============================================
# EMAILBISON (Webhooks + Defaults)
# ==============================================
EMAILBISON_WEBHOOK_SECRET=        # Required: HMAC secret for webhook signature verification
EMAILBISON_DEFAULT_ACCOUNT_ID=    # Optional: Default EB account ID

# ==============================================
# EMAIL SENDING (Addresses)
# ==============================================
RESEND_FROM_EMAIL=                # Default from address (e.g., notifications@yourdomain.com)
DEFAULT_FROM_EMAIL=               # Fallback from address
OUTREACH_FROM_EMAIL=              # SDR auto-reply from address
OUTREACH_FROM_NAME=               # SDR from name

# ==============================================
# ADMIN / SECURITY
# ==============================================
ADMIN_BYPASS_PASSWORD=            # Optional: Dev bypass password
AUTOMATION_SECRET=                # Required: Internal automation webhook auth
CURSIVE_WEBHOOK_SECRET=           # Required: Outbound webhook signing secret

# ==============================================
# AUDIENCELAB (Extended)
# ==============================================
AL_DAILY_QUOTA_PER_WORKSPACE=1000 # Optional: Daily lead quota per workspace (default 1000)
AUDIENCELAB_API_URL=              # Optional: Override AL API base URL

# ==============================================
# PLATFORM IDENTITY
# ==============================================
PLATFORM_WORKSPACE_ID=            # Required: The platform's own workspace ID for admin ops
NEXT_PUBLIC_PLATFORM_WORKSPACE_ID= # Required: Public version for client-side refs

# ==============================================
# INTEGRATIONS (configure as needed)
# ==============================================
# Slack OAuth
SLACK_CLIENT_ID=                  # Slack OAuth app client ID
SLACK_CLIENT_SECRET=              # Slack OAuth app client secret

# Twilio SMS
TWILIO_ACCOUNT_SID=               # Twilio SMS account SID
TWILIO_AUTH_TOKEN=                # Twilio auth token
TWILIO_PHONE_NUMBER=              # Twilio phone number

# RabbitSign (Contract signing)
RABBITSIGN_API_KEY_ID=            # RabbitSign API key ID
RABBITSIGN_API_SECRET=            # RabbitSign API secret
RABBITSIGN_CONTRACT_TEMPLATE_ID=  # Contract template ID

# Bland AI (AI calling)
BLAND_AI_API_KEY=                 # Bland AI API key
BLAND_WEBHOOK_SECRET=             # Bland webhook verification secret

# GoHighLevel CRM (Extended)
GHL_CLIENT_ID=                    # GoHighLevel OAuth app client ID
GHL_CLIENT_SECRET=                # GoHighLevel OAuth app client secret
GHL_CURSIVE_COMPANY_ID=           # Cursive's GHL company ID

# Cal.com (Booking)
CAL_WEBHOOK_SECRET=               # Cal.com booking webhook verification secret
CAL_BOOKING_URL=                  # Default booking link (e.g., https://cal.com/yourteam/30min)

# Clay (Enrichment)
CLAY_API_URL=                     # Clay enrichment API base URL
CLAY_WEBHOOK_SECRET=              # Clay webhook verification secret

# Google Maps
GOOGLE_MAPS_API_KEY=              # Address validation

# Mapbox
MAPBOX_ACCESS_TOKEN=              # Map rendering

# Web Search / Research
SERPER_API_KEY=                   # Web search enrichment (Serper)
PERPLEXITY_API_KEY=               # AI research (Perplexity)

# LinkedIn Enrichment
PROXYCURL_API_KEY=                # LinkedIn enrichment via Proxycurl

# Email Verification
NEVERBOUNCE_API_KEY=              # Email verification via NeverBounce

# ==============================================
# RATE LIMITING
# ==============================================
# Upstash Redis (distributed rate limiting — optional, falls back to in-memory)
# Get credentials from https://console.upstash.com after creating a Redis database.
# Without these, each Vercel replica maintains independent in-memory counters.
UPSTASH_REDIS_REST_URL=           # From Upstash console (e.g., https://....upstash.io)
UPSTASH_REDIS_REST_TOKEN=         # From Upstash console
