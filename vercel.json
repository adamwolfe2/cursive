{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "rm -rf .next && pnpm run build",
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "regions": ["pdx1"],
  "functions": {
    "src/app/api/**/*.ts": {
      "memory": 512
    },
    "src/app/api/inngest/route.ts": {
      "memory": 1024
    },
    "src/app/api/admin/run-enrichment/route.ts": {
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/cron/reset-lead-counts",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/db-health",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/segment-pull",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/affiliate-payouts",
      "schedule": "0 10 1 * *"
    },
    {
      "path": "/api/cron/sweep-stuck-onboarding",
      "schedule": "*/10 * * * *"
    }
  ]
}
